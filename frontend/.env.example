# Base URL da API Go (backend finance.sh).
# Dev com Vite (npm run dev): use o proxy relativo (recomendado) ou aponte direto:
#   - via proxy do Vite:        /api/v1
#   - direto no backend (dev):  http://localhost:8090/api/v1
# Em produção a SPA é servida pelo próprio binário Go (go:embed) → same-origin: /api/v1
VITE_API_URL=/api/v1
