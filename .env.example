# ============================================================================
# finance.sh — environment configuration
# Copy this file to .env and adjust as needed:  cp .env.example .env
# The dev defaults below let `docker compose up` work out of the box.
# !! Change ALL secrets/passwords before deploying to production. !!
#
# Host ports are intentionally NON-standard (8090/5433) to avoid clashing with
# other services. Container-internal ports are standard.
#
# Stack default = 2 containers (postgres + app). The app is a single Go binary
# serving the embedded SPA + JSON API on one HTTP port — no bundled TLS, bring
# your own reverse proxy. Única dependência externa: Postgres (anexos em BYTEA;
# cache/rate-limit in-memory; lockout/refresh no DB). Admin do DB via psql.
#
# A landing page (marketing) é um projeto/deploy à parte; não faz parte daqui.
# ============================================================================

# ---- App --------------------------------------------------------------------
APP_ENV=development          # development | production
APP_PORT=8090                # app HTTP port: local listen (make backend-dev) AND published host port (docker)
SWAGGER_ENABLED=true         # true in dev; MUST be false in production
FRONTEND_URL=http://localhost:8090  # public app URL (email links, CORS); use your proxy's https URL in prod

# ---- Primeiro acesso --------------------------------------------------------
# Default (false): banco vazio → SPA mostra o SETUP WIZARD, onde VOCÊ cria o 1º
# super-admin pela web (nenhum segredo é exibido). É o caminho seguro.
# true = deploy headless/automatizado: cria admin no boot; ADMIN_PASSWORD vazio
# gera senha aleatória e IMPRIME no log (1x). Sempre força troca no 1º login.
BOOTSTRAP_ADMIN=false
ADMIN_EMAIL=admin@finance.sh     # email do admin (só usado quando BOOTSTRAP_ADMIN=true)
ADMIN_PASSWORD=                  # vazio = senha aleatória no log (quando BOOTSTRAP_ADMIN=true)
ADMIN_ORG_NAME=Minha Organização # org criada junto (quando BOOTSTRAP_ADMIN=true)

# ---- Encryption (field-level PII / 2FA secret) ------------------------------
# base64-encoded 32 bytes (AES-256 GCM). The value below is the WELL-KNOWN DEV
# key — safe ONLY for local dev. In production the app REFUSES to boot with it,
# forcing you to set a unique one:  openssl rand -base64 32
# Losing/rotating this key makes encrypted fields unreadable.
ENCRYPTION_KEY=a23pl9SKFOJF39DSpLJaSL3NYHpSIORb+6MMpw20GbI=

# ---- Postgres ---------------------------------------------------------------
DB_HOST=localhost            # overridden to "postgres" inside docker compose
DB_PORT=5433                 # host port (matches PG_PORT); 5432 inside docker
DB_USER=finance_sh
DB_PASSWORD=finance_sh            # CHANGE IN PRODUCTION
DB_NAME=finance_sh
DB_SSLMODE=prefer            # dev: "prefer" (boots without server cert).
                             # prod: "require" or "verify-full" with a server cert.
PG_PORT=5433                 # host port published for postgres (local tooling, 127.0.0.1)

# ---- JWT --------------------------------------------------------------------
JWT_ACCESS_SECRET=dev-access-secret-change-me      # CHANGE IN PRODUCTION
JWT_REFRESH_SECRET=dev-refresh-secret-change-me    # CHANGE IN PRODUCTION
JWT_ACCESS_TTL_MIN=15        # access token lifetime (minutes)
JWT_REFRESH_TTL_DAYS=7       # refresh token lifetime (days)

# ---- Auth: brute-force lockout ----------------------------------------------
LOGIN_MAX_ATTEMPTS=5         # failed logins before the account is temporarily locked
LOGIN_LOCKOUT_MIN=15         # lockout duration (minutes)

# ---- SMTP (transactional email) ---------------------------------------------
# Leave empty in dev: the backend logs emails to stdout instead of sending.
SMTP_HOST=                   # e.g. smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=                   # CHANGE IN PRODUCTION
SMTP_FROM=no-reply@finance.sh

# ---- CORS / Rate limiting ---------------------------------------------------
# Same-origin in prod (SPA + API share the binary), so CORS only matters for the
# Vite dev server (5173). Add your proxy's origin if you serve the SPA elsewhere.
CORS_ORIGINS=http://localhost:8090,http://localhost:5173
# Rate limit é in-memory (token bucket por IP); aplicado por processo do backend.
RATE_LIMIT_RPM=120           # requests per minute per client

# ---- LGPD / data lifecycle --------------------------------------------------
RETENTION_DAYS=90            # days before soft-deleted/expired data is purged by the scheduler
TERMS_VERSION=1.0            # current Terms/Privacy version (consent is versioned)

# ---- Seed -------------------------------------------------------------------
SEED=false                   # set true to seed demo data on backend boot
                             # demo login once seeded: demo@finance.sh / senha123

# ---- Scheduler in-process ---------------------------------------------------
# true (default) = scheduler (recorrência, notificações, purga LGPD) roda como
# goroutine dentro da app.
# false = desliga o scheduler (ex.: múltiplas réplicas onde só uma agenda).
JOBS_IN_PROCESS=true
WORKER_INTERVAL_SEC=3600     # intervalo do loop do scheduler (segundos)

# ---- Reverse proxy / TLS ----------------------------------------------------
# No bundled nginx/TLS. The app publishes plain HTTP on APP_PORT (above); put
# your own reverse proxy (Traefik, Caddy, Nginx Proxy Manager) in front to
# terminate TLS. If the proxy runs on this host, bind APP_PORT to 127.0.0.1 in
# docker-compose.yml. See the README "Reverse proxy" section for examples.

# ---- Frontend ---------------------------------------------------------------
# The app binary serves the SPA, so the API is same-origin and /api/v1 is
# relative. For standalone Vite dev (npm run dev) use a full URL in frontend/.env.
VITE_API_URL=/api/v1
# URL da landing pública (deploy externo). Vazio = SPA esconde "Contratar"
# na tela de login. Setar pra https://finance.sh (ou domínio próprio) em prod.
VITE_LANDING_URL=
