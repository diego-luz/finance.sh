# ============================================================================
# finance.sh — repository ignore rules
# ============================================================================

# ---- Environment / secrets --------------------------------------------------
.env
.env.local
.env.*.local
*.local.env
!.env.example

# ---- Local tooling (Claude Code, editors) — never commit --------------------
.claude/
.idea/
.vscode/

# ---- Go (backend) -----------------------------------------------------------
backend/bin/
backend/tmp/
/vendor/
backend/vendor/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
coverage.out
coverage.html
backend/cofre
backend/api
backend/cmd/api/api

# ---- Node / Vite (frontend) -------------------------------------------------
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
.vite/
frontend/stats.html
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache

# ---- Docker / data volumes (if ever bind-mounted locally) -------------------
pgdata/

# ---- Encrypted DB backups --------------------------------------------------
backups/
*.sql.gpg
*.pem

# ---- Logs -------------------------------------------------------------------
*.log
logs/

# ---- IDE / editors ----------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# ---- OS ---------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
